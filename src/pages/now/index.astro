---
// ============================================================
// /now 页面（"此刻"）
// 从 Telegram 频道拉取带 #now 标签的消息，倒叙时间线展示
// 无限滚动加载，Viewer.js 图片预览
// ============================================================
import Base from '@/layouts/Base.astro';

const PAGE_TITLE = '此刻';
const PAGE_DESCRIPTION = '记录我此刻正在做什么、想什么、关注什么';
---

<Base
  head={{
    title: PAGE_TITLE,
    description: PAGE_DESCRIPTION,
  }}
>
  <div class="mx-auto w-full max-w-screen-lg px-4 py-6">
    <!-- 页面标题 -->
    <div class="flex items-center justify-center">
      <p class="text-4xl font-bold">此刻</p>
    </div>

    <!-- 静态回退：当 JS 未加载时显示提示 -->
    <noscript>
      <div class="mt-32 flex flex-col items-center justify-center text-center">
        <p class="text-sm text-stone-400 dark:text-stone-500">需要启用 JavaScript 来加载内容</p>
      </div>
    </noscript>

    <!-- 消息容器 -->
    <div id="now-container" class="mt-8"></div>

    <!-- 加载指示器 -->
    <div id="now-loader" class="mt-8 flex justify-center" style="display:none">
      <span class="text-sm text-stone-400 dark:text-stone-500">加载中...</span>
    </div>

    <!-- 已加载全部提示 -->
    <div id="now-end" class="mt-8 flex justify-center" style="display:none">
      <span class="text-xs text-stone-300 dark:text-stone-600">— 已加载全部 —</span>
    </div>

    <!-- stale 数据提示 -->
    <div id="now-stale" class="mt-4 flex justify-center" style="display:none">
      <span class="rounded-full bg-amber-100 px-3 py-1 text-xs text-amber-700 dark:bg-amber-900/30 dark:text-amber-400">
        数据可能不是最新的
      </span>
    </div>

    <!-- 错误提示 -->
    <div id="now-error" class="mt-32 flex flex-col items-center justify-center text-center" style="display:none">
      <p class="text-sm text-stone-400 dark:text-stone-500">暂时无法获取数据，请稍后重试</p>
    </div>

    <!-- 空状态 -->
    <div id="now-empty" class="mt-32 flex flex-col items-center justify-center text-center" style="display:none">
      <p class="text-sm text-stone-400 dark:text-stone-500">暂无记录</p>
    </div>
  </div>
</Base>

<!-- Viewer.js -->
<link rel="stylesheet" href="https://cdn.bootcdn.net/ajax/libs/viewerjs/1.11.6/viewer.min.css">
<script is:inline src="https://cdn.bootcdn.net/ajax/libs/viewerjs/1.11.6/viewer.min.js" defer></script>

<script>
  // ============================================================
  // /now 页面客户端逻辑
  // ============================================================

  interface NowMessage {
    id: string;
    text: string;
    images: string[];
    timestamp: string;
    link: string;
  }

  interface ApiResponse {
    messages: NowMessage[];
    hasRecentUpdate: boolean;
    stale?: boolean;
    error?: string;
  }

  const PAGE_SIZE = 20;
  let currentOffset = 0;
  let hasMore = true;
  let isLoading = false;

  // ---- DOM 元素 ----
  const container = document.getElementById('now-container')!;
  const loader = document.getElementById('now-loader')!;
  const endEl = document.getElementById('now-end')!;
  const staleEl = document.getElementById('now-stale')!;
  const errorEl = document.getElementById('now-error')!;
  const emptyEl = document.getElementById('now-empty')!;

  // ---- 工具函数 ----

  function relativeTime(dateStr: string): string {
    const now = Date.now();
    const date = new Date(dateStr).getTime();
    const diff = now - date;
    const minutes = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);

    if (minutes < 1) return '刚刚';
    if (minutes < 60) return `${minutes} 分钟前`;
    if (hours < 24) return `${hours} 小时前`;
    if (days < 7) return `${days} 天前`;
    if (days < 30) return `${Math.floor(days / 7)} 周前`;
    return new Date(dateStr).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function formatDate(dateStr: string): { monthDay: string; year: string } {
    const d = new Date(dateStr);
    return {
      monthDay: d.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' }),
      year: String(d.getFullYear()),
    };
  }

  // ---- 渲染 ----

  function createMessageCard(msg: NowMessage, isLatest: boolean): HTMLElement {
    const { monthDay, year } = formatDate(msg.timestamp);

    const wrapper = document.createElement('div');
    wrapper.className = `flex gap-4 py-5 border-b border-stone-200 dark:border-stone-800`;

    // 左侧：日期
    const dateCol = document.createElement('div');
    dateCol.className = 'w-20 shrink-0 text-right';
    dateCol.innerHTML = `
      <p class="text-xs text-stone-400 dark:text-stone-500 font-mono leading-tight">${monthDay}</p>
      <p class="text-[10px] text-stone-400/70 dark:text-stone-500/70 font-mono leading-tight mt-0.5">${year}</p>
    `;

    // 右侧：内容
    const contentCol = document.createElement('div');
    contentCol.className = 'min-w-0 flex-1';

    // 文字 + 最新标记
    const textHtml = escapeHtml(msg.text);
    const dotHtml = isLatest
      ? '<span class="ml-1.5 inline-block h-1.5 w-1.5 rounded-full bg-orange-500 align-middle"></span>'
      : '';

    // 图片
    let imagesHtml = '';
    if (msg.images.length > 0) {
      const imgTags = msg.images
        .map((src) => `<img src="${escapeHtml(src)}" alt="" class="h-16 w-16 shrink-0 cursor-pointer rounded-md object-cover" loading="lazy" />`)
        .join('');
      imagesHtml = `
        <div class="now-gallery mt-2">
          <div class="flex gap-1.5 overflow-x-auto">${imgTags}</div>
        </div>
      `;
    }

    contentCol.innerHTML = `
      <p class="text-sm leading-relaxed text-stone-700 dark:text-stone-300">
        ${textHtml}${dotHtml}
      </p>
      ${imagesHtml}
      <div class="mt-1.5 flex items-center gap-3 text-[11px] text-stone-400 dark:text-stone-500">
        <span>${relativeTime(msg.timestamp)}</span>
        <a href="${escapeHtml(msg.link)}" target="_blank" rel="noopener noreferrer" class="hover:text-orange-600 transition-colors">
          Telegram →
        </a>
      </div>
    `;

    wrapper.appendChild(dateCol);
    wrapper.appendChild(contentCol);
    return wrapper;
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // ---- Viewer.js 初始化 ----

  function initViewer() {
    // 销毁旧实例
    document.querySelectorAll('.now-gallery').forEach((gallery) => {
      const imgs = gallery.querySelectorAll('img');
      imgs.forEach((img) => {
        (img as any)._viewer?.destroy();
      });
    });

    // 为每个画廊初始化
    document.querySelectorAll('.now-gallery').forEach((gallery) => {
      const imgs = gallery.querySelectorAll('img');
      if (imgs.length === 0) return;

      if (imgs.length === 1) {
        new (window as any).Viewer(imgs[0], {
          button: false,
          navbar: false,
          title: false,
          toolbar: {
            zoomIn: 4, zoomOut: 4, oneToOne: 4, reset: 0,
            prev: 0, play: 0, next: 0, rotateLeft: 4, rotateRight: 4,
            flipHorizontal: 0, flipVertical: 0,
          },
        });
      } else {
        new (window as any).Viewer(gallery, {
          button: false,
          navbar: false,
          title: false,
          toolbar: {
            zoomIn: 4, zoomOut: 4, oneToOne: 4, reset: 0,
            prev: 0, play: 0, next: 0, rotateLeft: 4, rotateRight: 4,
            flipHorizontal: 0, flipVertical: 0,
          },
        });
      }
    });
  }

  // ---- 数据加载 ----

  async function fetchMessages(offset: number): Promise<ApiResponse> {
    const params = new URLSearchParams({ limit: String(PAGE_SIZE), offset: String(offset) });
    const res = await fetch(`/api/now.json?${params}`);
    if (!res.ok) {
      throw new Error(`API returned ${res.status}`);
    }
    return res.json();
  }

  function appendMessages(messages: NowMessage[], isFirstPage: boolean) {
    const fragment = document.createDocumentFragment();

    messages.forEach((msg, i) => {
      const isLatest = isFirstPage && i === 0;
      fragment.appendChild(createMessageCard(msg, isLatest));
    });

    container.appendChild(fragment);

    // 重新初始化 Viewer.js
    initViewer();
  }

  async function loadFirstPage() {
    isLoading = true;
    try {
      const data = await fetchMessages(0);
      currentOffset = data.messages.length;
      hasMore = data.messages.length >= PAGE_SIZE;

      if (data.error) {
        showError();
        return;
      }

      if (data.messages.length === 0) {
        showEmpty();
        return;
      }

      if (data.stale) {
        staleEl.style.display = '';
      }

      appendMessages(data.messages, true);

      // 通知 Navbar 更新状态
      window.dispatchEvent(new CustomEvent('now-page-loaded', {
        detail: { hasRecentUpdate: data.hasRecentUpdate },
      }));

      if (!hasMore) {
        endEl.style.display = '';
      }
    } catch {
      showError();
    } finally {
      isLoading = false;
    }
  }

  async function loadNextPage() {
    if (isLoading || !hasMore) return;
    isLoading = true;
    loader.style.display = '';

    try {
      const data = await fetchMessages(currentOffset);
      if (data.messages.length === 0) {
        hasMore = false;
        endEl.style.display = '';
        loader.style.display = 'none';
        return;
      }

      currentOffset += data.messages.length;
      hasMore = data.messages.length >= PAGE_SIZE;

      appendMessages(data.messages, false);

      if (!hasMore) {
        endEl.style.display = '';
      }
    } catch {
      // 加载更多失败：静默处理，保留已显示内容
      hasMore = false;
      endEl.style.display = '';
    } finally {
      isLoading = false;
      loader.style.display = 'none';
    }
  }

  // ---- 状态切换 ----

  function hideAll() {
    loader.style.display = 'none';
    endEl.style.display = 'none';
    staleEl.style.display = 'none';
    errorEl.style.display = 'none';
    emptyEl.style.display = 'none';
  }

  function showError() {
    hideAll();
    if (container.children.length === 0) {
      errorEl.style.display = '';
    }
  }

  function showEmpty() {
    hideAll();
    emptyEl.style.display = '';
  }

  // ---- 无限滚动 ----

  function setupInfiniteScroll() {
    const sentinel = document.createElement('div');
    sentinel.id = 'scroll-sentinel';
    sentinel.className = 'h-1';
    container.parentElement?.appendChild(sentinel);

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && hasMore && !isLoading) {
          loadNextPage();
        }
      },
      { rootMargin: '200px' }
    );

    observer.observe(sentinel);
  }

  // ---- 启动 ----

  function init() {
    hideAll();
    setupInfiniteScroll();
    loadFirstPage();
  }

  // 等待 Viewer.js 加载完成
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
