---
import Base from '@/layouts/Base.astro';
---

<Base head={{ title: '此刻', description: '记录我此刻正在做什么、想什么、关注什么' }}>
  <main class="mx-auto w-full max-w-screen-lg px-4 py-6">
    <h1 class="text-center text-4xl font-bold">此刻</h1>
    <noscript><p class="mt-32 text-center text-sm text-stone-400">需要启用 JavaScript 来加载内容</p></noscript>
    <div id="now-container" class="mt-8"></div>
    <p id="now-loader" class="mt-8 hidden text-center text-sm text-stone-400">加载中...</p>
    <div id="now-initial-error" class="mt-32 hidden text-center">
      <p class="text-sm text-stone-400">暂时无法获取数据，请稍后重试</p>
      <button class="mt-3 rounded-lg bg-stone-200 px-4 py-2 text-sm dark:bg-stone-800">重试</button>
    </div>
    <div id="now-more-error" class="mt-8 hidden text-center">
      <p class="text-sm text-stone-400">加载更多失败</p>
      <button class="mt-2 text-sm text-orange-600 hover:underline">重试</button>
    </div>
    <p id="now-empty" class="mt-32 hidden text-center text-sm text-stone-400">暂无记录</p>
    <p id="now-end" class="mt-8 hidden text-center text-xs text-stone-300 dark:text-stone-600">— 已加载全部 —</p>
    <div id="now-sentinel" class="h-1"></div>
  </main>
</Base>

<link rel="stylesheet" href="https://cdn.bootcdn.net/ajax/libs/viewerjs/1.11.6/viewer.min.css" />
<script is:inline src="https://cdn.bootcdn.net/ajax/libs/viewerjs/1.11.6/viewer.min.js" defer></script>

<script>
  import { NowFeed, type NowMessage, type NowPage } from '@/utils/now/feed';

  const container = document.querySelector<HTMLElement>('#now-container')!;
  const loader = document.querySelector<HTMLElement>('#now-loader')!;
  const initialError = document.querySelector<HTMLElement>('#now-initial-error')!;
  const moreError = document.querySelector<HTMLElement>('#now-more-error')!;
  const empty = document.querySelector<HTMLElement>('#now-empty')!;
  const end = document.querySelector<HTMLElement>('#now-end')!;
  const hide = (element: HTMLElement) => element.classList.add('hidden');
  const show = (element: HTMLElement) => element.classList.remove('hidden');

  function safeHttpUrl(value: string | undefined): string | undefined {
    if (!value) return undefined;
    try {
      const url = new URL(value);
      return url.protocol === 'http:' || url.protocol === 'https:' ? url.href : undefined;
    } catch { return undefined; }
  }

  function linkedText(message: NowMessage): DocumentFragment {
    const fragment = document.createDocumentFragment();
    let position = 0;
    const entities = [...message.entities]
      .filter((entity) => entity.type === 'url' || entity.type === 'text_link')
      .sort((left, right) => left.offset - right.offset);
    for (const entity of entities) {
      if (entity.offset < position || entity.offset + entity.length > message.text.length) continue;
      fragment.append(document.createTextNode(message.text.slice(position, entity.offset)));
      const label = message.text.slice(entity.offset, entity.offset + entity.length);
      const href = safeHttpUrl(entity.type === 'url' ? label : entity.url);
      if (href) {
        const anchor = document.createElement('a');
        anchor.href = href;
        anchor.target = '_blank';
        anchor.rel = 'noopener noreferrer';
        anchor.className = 'text-orange-600 hover:underline';
        anchor.textContent = label;
        fragment.append(anchor);
      } else fragment.append(document.createTextNode(label));
      position = entity.offset + entity.length;
    }
    fragment.append(document.createTextNode(message.text.slice(position)));
    return fragment;
  }

  function lucideChevron(direction: 'left' | 'right'): SVGSVGElement {
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'none');
    svg.setAttribute('stroke', 'currentColor');
    svg.setAttribute('stroke-width', '2');
    svg.setAttribute('stroke-linecap', 'round');
    svg.setAttribute('stroke-linejoin', 'round');
    svg.setAttribute('class', 'h-5 w-5');
    svg.setAttribute('aria-hidden', 'true');

    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', direction === 'left' ? 'm15 18-6-6 6-6' : 'm9 18 6-6-6-6');
    svg.append(path);
    return svg;
  }

  function galleryButton(direction: 'left' | 'right'): HTMLButtonElement {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = `${direction === 'left' ? 'left-2' : 'right-2'} pointer-events-auto absolute top-1/2 hidden h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-stone-700 shadow-sm ring-1 ring-stone-200 transition hover:bg-white hover:text-orange-600 dark:bg-stone-900/90 dark:text-stone-200 dark:ring-stone-700 dark:hover:bg-stone-900`;
    button.setAttribute('aria-label', direction === 'left' ? '切换上一张图片' : '切换下一张图片');
    button.append(lucideChevron(direction));
    return button;
  }

  function card(message: NowMessage): HTMLElement {
    const row = document.createElement('article');
    row.className = 'border-b border-stone-200 py-5 dark:border-stone-800';
    const date = new Date(message.timestamp);
    const dateColumn = document.createElement('time');
    dateColumn.className = 'mb-2 block font-mono text-[11px] text-stone-400 dark:text-stone-500';
    dateColumn.dateTime = message.timestamp;
    dateColumn.textContent = `${date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric', year: 'numeric' })} ${date.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })}`;
    const content = document.createElement('div');
    content.className = 'min-w-0';
    const text = document.createElement('p');
    text.className = 'whitespace-pre-wrap break-words text-sm leading-relaxed text-stone-700 dark:text-stone-300';
    text.append(linkedText(message));
    const galleryWrap = document.createElement('div');
    galleryWrap.className = 'group relative mt-3 min-w-0';
    const gallery = document.createElement('div');
    gallery.className = 'now-gallery flex snap-x gap-2 overflow-x-auto scroll-smooth';
    gallery.dataset.nowGallery = '';
    for (const image of message.images) {
      const element = document.createElement('img');
      element.src = `/api/now-images/${encodeURIComponent(image.id)}`;
      element.alt = '';
      element.loading = 'lazy';
      element.width = image.width;
      element.height = image.height;
      element.className = 'h-40 w-auto max-w-[80%] shrink-0 snap-start cursor-zoom-in rounded-lg object-cover';
      gallery.append(element);
    }
    const previousButton = galleryButton('left');
    const nextButton = galleryButton('right');
    previousButton.onclick = () => {
      const previousImages = Array.from(gallery.children).filter((image) => {
        return image instanceof HTMLElement && image.offsetLeft < gallery.scrollLeft - 8;
      });
      const previousImage = previousImages.at(-1);
      const previousScrollLeft = previousImage instanceof HTMLElement
        ? previousImage.offsetLeft
        : Math.max(gallery.scrollLeft - gallery.clientWidth * 0.75, 0);
      gallery.scrollTo({
        left: Math.max(previousScrollLeft, 0),
        behavior: 'smooth',
      });
    };
    nextButton.onclick = () => {
      const maxScrollLeft = gallery.scrollWidth - gallery.clientWidth;
      const nextImage = Array.from(gallery.children).find((image) => {
        return image instanceof HTMLElement && image.offsetLeft > gallery.scrollLeft + 8;
      });
      const nextScrollLeft = nextImage instanceof HTMLElement
        ? nextImage.offsetLeft
        : Math.min(gallery.scrollLeft + gallery.clientWidth * 0.75, maxScrollLeft);
      gallery.scrollTo({
        left: Math.min(nextScrollLeft, maxScrollLeft),
        behavior: 'smooth',
      });
    };
    const syncGalleryButtons = () => {
      const maxScrollLeft = gallery.scrollWidth - gallery.clientWidth;
      const isOverflowing = maxScrollLeft > 1;
      const isAtStart = gallery.scrollLeft <= 1;
      const isAtEnd = gallery.scrollLeft >= maxScrollLeft - 1;
      const showPrevious = isOverflowing && !isAtStart;
      const showNext = isOverflowing && !isAtEnd;

      previousButton.classList.toggle('hidden', !showPrevious);
      previousButton.classList.toggle('flex', showPrevious);
      nextButton.classList.toggle('hidden', !showNext);
      nextButton.classList.toggle('flex', showNext);
    };
    requestAnimationFrame(syncGalleryButtons);
    gallery.addEventListener('scroll', syncGalleryButtons, { passive: true });
    window.addEventListener('resize', syncGalleryButtons);
    gallery.querySelectorAll('img').forEach((image) => {
      image.addEventListener('load', syncGalleryButtons, { once: true });
    });
    galleryWrap.append(gallery, previousButton, nextButton);
    const source = document.createElement('a');
    source.href = message.link;
    source.target = '_blank';
    source.rel = 'noopener noreferrer';
    source.className = 'mt-2 inline-block text-[11px] text-stone-400 hover:text-orange-600';
    source.textContent = 'Telegram →';
    content.append(text);
    if (message.images.length) content.append(galleryWrap);
    content.append(source);
    row.append(dateColumn, content);
    return row;
  }

  function add(messages: NowMessage[]) {
    const fragment = document.createDocumentFragment();
    messages.forEach((message) => fragment.append(card(message)));
    container.append(fragment);
    const Viewer = (window as typeof window & { Viewer?: new (element: Element, options: object) => unknown }).Viewer;
    if (Viewer) {
      container.querySelectorAll('[data-now-gallery]:not([data-viewer-ready])').forEach((gallery) => {
        gallery.setAttribute('data-viewer-ready', '');
        new Viewer(gallery, { button: false, title: false, navbar: true });
      });
    }
  }

  async function fetchPage(cursor: string | null): Promise<NowPage> {
    const params = new URLSearchParams({ limit: '20' });
    if (cursor) params.set('cursor', cursor);
    const response = await fetch(`/api/now.json?${params}`);
    if (!response.ok) throw new Error(`Now API returned ${response.status}`);
    return response.json();
  }

  const feed = new NowFeed(fetchPage, {
    replace(messages) { container.replaceChildren(); hide(initialError); hide(moreError); add(messages); },
    append(messages) { hide(moreError); add(messages); },
    showEmpty() { show(empty); },
    showEnd() { show(end); },
    showInitialError(retry) {
      show(initialError);
      initialError.querySelector('button')!.onclick = () => void retry();
    },
    showMoreError(retry) {
      show(moreError);
      moreError.querySelector('button')!.onclick = () => void retry();
    },
    setLoading(loading) { loader.classList.toggle('hidden', !loading); },
  });

  void feed.loadFirst();
  new IntersectionObserver((entries) => {
    if (entries[0]?.isIntersecting) void feed.loadMore();
  }, { rootMargin: '200px' }).observe(document.querySelector('#now-sentinel')!);
</script>

<style is:global>
  .now-gallery {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .now-gallery::-webkit-scrollbar {
    display: none;
  }
</style>
