---
import Base from '@/layouts/Base.astro';
---

<Base head={{ title: '此刻', description: '记录我此刻正在做什么、想什么、关注什么' }}>
  <main class="mx-auto w-full max-w-screen-lg px-4 py-6">
    <h1 class="text-center text-4xl font-bold">此刻</h1>
    <noscript><p class="mt-32 text-center text-sm text-stone-400">需要启用 JavaScript 来加载内容</p></noscript>
    <div id="now-container" class="mt-8"></div>
    <p id="now-loader" class="mt-8 hidden text-center text-sm text-stone-400">加载中...</p>
    <div id="now-initial-error" class="mt-32 hidden text-center">
      <p class="text-sm text-stone-400">暂时无法获取数据，请稍后重试</p>
      <button class="mt-3 rounded-lg bg-stone-200 px-4 py-2 text-sm dark:bg-stone-800">重试</button>
    </div>
    <div id="now-more-error" class="mt-8 hidden text-center">
      <p class="text-sm text-stone-400">加载更多失败</p>
      <button class="mt-2 text-sm text-orange-600 hover:underline">重试</button>
    </div>
    <p id="now-empty" class="mt-32 hidden text-center text-sm text-stone-400">暂无记录</p>
    <p id="now-end" class="mt-8 hidden text-center text-xs text-stone-300 dark:text-stone-600">— 已加载全部 —</p>
    <div id="now-sentinel" class="h-1"></div>
  </main>
</Base>

<script>
  import { NowFeed, type NowMessage, type NowPage } from '@/utils/now/feed';

  const container = document.querySelector<HTMLElement>('#now-container')!;
  const loader = document.querySelector<HTMLElement>('#now-loader')!;
  const initialError = document.querySelector<HTMLElement>('#now-initial-error')!;
  const moreError = document.querySelector<HTMLElement>('#now-more-error')!;
  const empty = document.querySelector<HTMLElement>('#now-empty')!;
  const end = document.querySelector<HTMLElement>('#now-end')!;
  const hide = (element: HTMLElement) => element.classList.add('hidden');
  const show = (element: HTMLElement) => element.classList.remove('hidden');

  function safeHttpUrl(value: string | undefined): string | undefined {
    if (!value) return undefined;
    try {
      const url = new URL(value);
      return url.protocol === 'http:' || url.protocol === 'https:' ? url.href : undefined;
    } catch { return undefined; }
  }

  function linkedText(message: NowMessage): DocumentFragment {
    const fragment = document.createDocumentFragment();
    let position = 0;
    const entities = [...message.entities]
      .filter((entity) => entity.type === 'url' || entity.type === 'text_link')
      .sort((left, right) => left.offset - right.offset);
    for (const entity of entities) {
      if (entity.offset < position || entity.offset + entity.length > message.text.length) continue;
      fragment.append(document.createTextNode(message.text.slice(position, entity.offset)));
      const label = message.text.slice(entity.offset, entity.offset + entity.length);
      const href = safeHttpUrl(entity.type === 'url' ? label : entity.url);
      if (href) {
        const anchor = document.createElement('a');
        anchor.href = href;
        anchor.target = '_blank';
        anchor.rel = 'noopener noreferrer';
        anchor.className = 'text-orange-600 hover:underline';
        anchor.textContent = label;
        fragment.append(anchor);
      } else fragment.append(document.createTextNode(label));
      position = entity.offset + entity.length;
    }
    fragment.append(document.createTextNode(message.text.slice(position)));
    return fragment;
  }

  function card(message: NowMessage): HTMLElement {
    const row = document.createElement('article');
    row.className = 'flex gap-4 border-b border-stone-200 py-5 dark:border-stone-800';
    const date = new Date(message.timestamp);
    const dateColumn = document.createElement('time');
    dateColumn.className = 'w-20 shrink-0 text-right font-mono text-xs text-stone-400';
    dateColumn.dateTime = message.timestamp;
    dateColumn.textContent = date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric', year: 'numeric' });
    const content = document.createElement('div');
    content.className = 'min-w-0 flex-1';
    const text = document.createElement('p');
    text.className = 'whitespace-pre-wrap break-words text-sm leading-relaxed text-stone-700 dark:text-stone-300';
    text.append(linkedText(message));
    const source = document.createElement('a');
    source.href = message.link;
    source.target = '_blank';
    source.rel = 'noopener noreferrer';
    source.className = 'mt-2 inline-block text-[11px] text-stone-400 hover:text-orange-600';
    source.textContent = 'Telegram →';
    content.append(text, source);
    row.append(dateColumn, content);
    return row;
  }

  function add(messages: NowMessage[]) {
    const fragment = document.createDocumentFragment();
    messages.forEach((message) => fragment.append(card(message)));
    container.append(fragment);
  }

  async function fetchPage(cursor: string | null): Promise<NowPage> {
    const params = new URLSearchParams({ limit: '20' });
    if (cursor) params.set('cursor', cursor);
    const response = await fetch(`/api/now.json?${params}`);
    if (!response.ok) throw new Error(`Now API returned ${response.status}`);
    return response.json();
  }

  const feed = new NowFeed(fetchPage, {
    replace(messages) { container.replaceChildren(); hide(initialError); hide(moreError); add(messages); },
    append(messages) { hide(moreError); add(messages); },
    showEmpty() { show(empty); },
    showEnd() { show(end); },
    showInitialError(retry) {
      show(initialError);
      initialError.querySelector('button')!.onclick = () => void retry();
    },
    showMoreError(retry) {
      show(moreError);
      moreError.querySelector('button')!.onclick = () => void retry();
    },
    setLoading(loading) { loader.classList.toggle('hidden', !loading); },
  });

  void feed.loadFirst();
  new IntersectionObserver((entries) => {
    if (entries[0]?.isIntersecting) void feed.loadMore();
  }, { rootMargin: '200px' }).observe(document.querySelector('#now-sentinel')!);
</script>
